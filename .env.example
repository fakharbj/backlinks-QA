ENVIRONMENT=dev
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

PUBLIC_BASE_URL=http://localhost
CORS_ORIGINS=http://localhost,http://localhost:3000
DOCS_ENABLED=true

POSTGRES_DB=linksentinel
POSTGRES_USER=linksentinel
POSTGRES_PASSWORD=linksentinel
DATABASE_URL=postgresql+asyncpg://linksentinel:linksentinel@postgres:5432/linksentinel
DATABASE_REPLICA_URL=
DB_USE_PGBOUNCER=false

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

JWT_SECRET=change-this-to-a-very-long-random-secret-before-production
SECRETS_ENCRYPTION_KEY=change-this-to-a-long-random-secret-before-production

S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=linksentinel
S3_SECRET_KEY=linksentinel-secret
S3_BUCKET_SNAPSHOTS=ls-snapshots
S3_BUCKET_REPORTS=ls-reports
S3_BUCKET_IMPORTS=ls-imports
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=linksentinel
MINIO_ROOT_PASSWORD=linksentinel-secret

CRAWL_USER_AGENT=LinkSentinelBot/1.0 (+https://linksentinel.example/bot; backlink QA; contact: ops@linksentinel.example)
CRAWL_GLOBAL_CONCURRENCY=200
CRAWL_DEFAULT_RATE_PER_SEC=1
CRAWL_DEFAULT_BURST=2
CRAWL_RESPECT_ROBOTS=true
RENDER_ENABLED=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@linksentinel.example
SMTP_USE_TLS=true

NEXT_PUBLIC_API_BASE_URL=/api/v1
SEED_DEMO=false
