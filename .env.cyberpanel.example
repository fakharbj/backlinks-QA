# Compose interpolation values for CyberPanel/OpenLiteSpeed deployments.
# Copy to .env.cyberpanel and run:
#   docker compose --env-file .env.cyberpanel up -d --build

ENV_FILE=.env.production

# CyberPanel owns public 80/443. Docker nginx listens only on localhost.
PROXY_PORT=127.0.0.1:8080

# Keep admin tools private on the VPS. Use SSH tunnels when needed.
MINIO_API_PORT=127.0.0.1:9000
MINIO_CONSOLE_PORT=127.0.0.1:9001
FLOWER_PORT=127.0.0.1:5555
